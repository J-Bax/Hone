# =============================================================================
# Hone .gitignore
# =============================================================================

# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- PowerShell -----
*.ps1xml

# ----- k6 -----
# k6 binary (if downloaded locally)
k6.exe
k6

# ----- Node (if any tooling uses it) -----
node_modules/

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Hone Results -----
# Performance results are stored per-run in sample-api/results/.
# Baselines, k6 summaries, and run metadata are committed for review.
# Counters, Copilot logs, dashboard, and operational files are gitignored.
sample-api/results/*
!sample-api/results/.gitkeep
!sample-api/results/baseline.json
!sample-api/results/baseline-*.json
!sample-api/results/run-metadata.json
!sample-api/results/iteration-*/
sample-api/results/iteration-*/*
!sample-api/results/iteration-*/k6-summary*.json
