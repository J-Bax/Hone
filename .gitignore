# ----- .NET / C# -----
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
**/Properties/launchSettings.json

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json

# ----- SQL Server -----
*.mdf
*.ldf

# ----- PowerShell -----
*.ps1xml

# ----- k6 -----
# k6 binary (if downloaded locally)
k6.exe
k6

# ----- Node (if any tooling uses it) -----
node_modules/

# ----- IDE / Editor -----
.vs/
.vscode/settings.json
.vscode/launch.json
*.swp
*.swo
*~
.idea/

# ----- OS -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ----- Hone Tools (downloaded, not committed) -----
tools/

# ----- Hone Results -----
# NOTE: sample-api/ is a git submodule with its own .gitignore.
# The rules below do NOT take effect for the parent repo because git
# delegates ignore rules inside submodules to the submodule's own
# .gitignore. They are kept here for documentation purposes so
# contributors understand the intended ignore policy for results.
#
# Performance results are stored per-run in sample-api/results/.
# All result artifacts are committed for review.
sample-api/results/*
!sample-api/results/.gitkeep
!sample-api/results/baseline.json
!sample-api/results/baseline-*.json
!sample-api/results/run-metadata.json
!sample-api/results/hone.jsonl
!sample-api/results/experiment-*/
