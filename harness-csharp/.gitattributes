# =============================================================================
# Line-ending normalization for harness-csharp
# Ensures CRLF checkout on all platforms, matching .editorconfig end_of_line.
# =============================================================================

# Normalize all text files
* text=auto

# C# source — force CRLF to match .editorconfig / Roslyn IDE0055
*.cs text eol=crlf

# Project / build files
*.csproj text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.sln text eol=crlf
*.slnx text eol=crlf

# Config
*.editorconfig text eol=crlf
